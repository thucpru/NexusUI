// NexusUI — Prisma Schema
// PostgreSQL database with Prisma ORM
// Phase 2: Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum AIModelProvider {
  ANTHROPIC
  OPENAI
  GOOGLE
  CUSTOM
}

enum GenerationStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

enum CreditOperationType {
  PURCHASE
  GENERATION_DEDUCT
  GENERATION_REFUND
  ADMIN_ADJUSTMENT
  INITIAL_GRANT
}

enum SyncStatus {
  IDLE
  SYNCING
  ERROR
}

enum RefactoringStatus {
  PENDING
  SCANNING
  ANALYZED
  BEAUTIFYING
  VALIDATING
  PR_CREATED
  COMPLETED
  FAILED
}

enum StyleIssueType {
  INCONSISTENT_SPACING
  OUTDATED_CLASSES
  MISSING_RESPONSIVE
  POOR_CONTRAST
  INLINE_STYLES
  HARDCODED_COLORS
  NO_DESIGN_TOKENS
}

// ─── Models ────────────────────────────────────────────────────────────────────

/// User profile synced from Clerk. creditBalance is a cached sum of CreditLedger.
model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  name          String
  avatarUrl     String?
  role          UserRole @default(USER)
  creditBalance Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  projects         Project[]
  generations      Generation[]
  creditLedger     CreditLedger[]
  refactoringJobs  RefactoringJob[]

  @@map("users")
}

/// Workspace project linked to an optional Figma file.
model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  figmaFileId  String?
  figmaFileUrl String?
  userId       String
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  designSystem     DesignSystem?
  generations      Generation[]
  githubConnection GitHubConnection?
  componentAudits  ComponentAudit[]
  refactoringJobs  RefactoringJob[]

  @@index([userId])
  @@map("projects")
}

/// Design token set for a project. 1:1 with Project.
model DesignSystem {
  id               String   @id @default(cuid())
  projectId        String   @unique
  colorTokens      Json     @default("{}")
  typographyTokens Json     @default("{}")
  spacingTokens    Json     @default("{}")
  componentTokens  Json     @default("{}")
  version          Int      @default(1)
  updatedAt        DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("design_systems")
}

/// Admin-managed AI model registry. providerApiKey stored encrypted.
model AIModel {
  id                   String          @id @default(cuid())
  name                 String
  slug                 String          @unique
  provider             AIModelProvider
  providerModelId      String
  creditCostPerRequest Int
  providerApiKey       String
  isActive             Boolean         @default(true)
  description          String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  generations Generation[]

  @@index([isActive])
  @@map("ai_models")
}

/// AI generation job. designSystemSnapshot freezes tokens at generation time.
model Generation {
  id                   String           @id @default(cuid())
  projectId            String
  userId               String
  aiModelId            String
  prompt               String
  designSystemSnapshot Json
  output               Json?
  status               GenerationStatus @default(QUEUED)
  creditsCost          Int
  variantCount         Int              @default(1)
  framework            String           @default("react")
  errorMessage         String?
  createdAt            DateTime         @default(now())
  completedAt          DateTime?

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiModel AIModel @relation(fields: [aiModelId], references: [id])

  @@index([projectId, createdAt])
  @@index([userId])
  @@map("generations")
}

/// Append-only credit ledger. Never UPDATE or DELETE rows.
model CreditLedger {
  id              String              @id @default(cuid())
  userId          String
  operationType   CreditOperationType
  amount          Int
  balanceAfter    Int
  description     String
  referenceId     String?
  referenceType   String?
  stripeSessionId String?
  createdAt       DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_ledger")
}

/// Admin-configured credit packages for purchase.
model CreditPackage {
  id            String   @id @default(cuid())
  name          String
  creditAmount  Int
  bonusCredits  Int      @default(0)
  priceInCents  Int
  currency      String   @default("usd")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  stripePriceId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive])
  @@map("credit_packages")
}

/// GitHub App installation linked to a project. 1:1 with Project.
model GitHubConnection {
  id             String     @id @default(cuid())
  projectId      String     @unique
  installationId BigInt
  repoOwner      String
  repoName       String
  branch         String     @default("main")
  lastSyncAt     DateTime?
  syncStatus     SyncStatus @default(IDLE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("github_connections")
}

/// Audit record of a UI component's style issues, produced by the scanning phase.
model ComponentAudit {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  filePath         String
  componentName    String
  styleIssues      Json     // Array of {type: StyleIssueType, detail: string}
  issueCount       Int      @default(0)
  estimatedCredits Int      @default(0)
  logicSafety      String   @default("SAFE") // SAFE, RISKY, MANUAL_REVIEW
  lastScannedAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, issueCount])
  @@map("component_audits")
}

/// A single UI refactoring job for one component, tracking status from scan to PR.
model RefactoringJob {
  id              String            @id @default(cuid())
  projectId       String
  project         Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  componentPath   String
  componentName   String
  status          RefactoringStatus @default(PENDING)
  beforeCode      String?           @db.Text
  afterCode       String?           @db.Text
  diffPreview     String?           @db.Text
  styleChanges    Json?
  logicValidation Json?
  aiModelId       String?
  creditsUsed     Int               @default(0)
  githubPrUrl     String?
  githubBranch    String?
  errorMessage    String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([projectId])
  @@index([userId])
  @@index([status])
  @@index([projectId, status])
  @@map("refactoring_jobs")
}
